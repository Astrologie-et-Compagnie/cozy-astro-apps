// Short CEO one-liners for quiet days
const QUIET_INSIGHTS={
  1:"Virgo Moon opens the month. Organize your April game plan. Refine before you launch.",
  5:"Deep Scorpio Moon. Journal on what's holding you back. The insight you need is underneath the discomfort.",
  6:"Still in Scorpio waters. Let the intensity do its work. Not every day needs to be productive to be powerful.",
  8:"Sagittarius Moon dreams big. Capture those visions. The details come later, the direction matters now.",
  11:"Aquarius Moon. Innovation over convention. What assumption are you ready to challenge?",
  13:"Pisces Moon. Rest is a strategy, not a weakness. Protect your energy for what's coming.",
  21:"Gemini Moon meets Taurus season. Write, share, connect. Your ideas are ready to circulate.",
  22:"Cancer Moon. Nurture what you've built. Check in on your community. A personal touch goes further than a broadcast.",
  27:"Virgo Moon. Refine, edit, optimize. The details you polish now will shine when it matters.",
  29:"Libra Moon. Review your partnerships and collaborations. Is the energy balanced?"
};

const grid=document.getElementById('calendar-grid');
const overlay=document.getElementById('detailOverlay');
const detailContent=document.getElementById('detailContent');
const closeBtn=document.getElementById('detailClose');

let currentFilter='all';
const MAX_VISIBLE_EVENTS=4;

function buildCalendar(filter){
  currentFilter=filter;
  grid.innerHTML='';
  
  const headerRow=document.createElement('div');
  headerRow.className='week-row';
  ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'].forEach(d=>{
    const h=document.createElement('div');
    h.className='day-header';h.textContent=d;headerRow.appendChild(h);
  });
  grid.appendChild(headerRow);
  
  const startDay=2; // April 2026 starts Wednesday (0=Mon)
  let row=document.createElement('div');
  row.className='week-row';
  
  for(let i=0;i<startDay;i++){
    const empty=document.createElement('div');
    empty.className='day-cell empty';row.appendChild(empty);
  }
  
  for(let day=1;day<=30;day++){
    const cell=document.createElement('div');
    cell.className='day-cell';
    
    const allDayEvents=EVENTS.filter(e=>e.day===day);
    const filteredEvents=filter==='all'?allDayEvents:allDayEvents.filter(e=>e.type===filter);
    
    // Highlight special days
    if(allDayEvents.some(e=>e.type==='phase'))cell.classList.add('has-phase');
    if(allDayEvents.some(e=>e.type==='planet'))cell.classList.add('has-planet');
    
    if(filter!=='all'&&filteredEvents.length===0&&allDayEvents.length>0){
      cell.style.opacity='.3';
    }
    
    // Top row: number + moon badge
    const top=document.createElement('div');
    top.className='day-top';
    const num=document.createElement('div');
    num.className='day-num';num.textContent=day;
    top.appendChild(num);
    if(MOON_SIGNS[day]){
      const badge=document.createElement('div');
      badge.className='day-moon-badge';
      badge.textContent='☽ '+MOON_SIGNS[day];
      top.appendChild(badge);
    }
    cell.appendChild(top);
    
    // Event mini-labels
    const evContainer=document.createElement('div');
    evContainer.className='day-events';
    
    const displayEvents=filter==='all'?allDayEvents:filteredEvents;
    const visible=displayEvents.slice(0,MAX_VISIBLE_EVENTS);
    const overflow=displayEvents.length-MAX_VISIBLE_EVENTS;
    
    visible.forEach(ev=>{
      const mini=document.createElement('div');
      mini.className='day-event-mini '+ev.type;
      mini.textContent=ev.mini;
      evContainer.appendChild(mini);
    });
    
    if(overflow>0){
      const more=document.createElement('div');
      more.className='day-more';
      more.textContent='+'+overflow+' more';
      evContainer.appendChild(more);
    }
    
    // Quiet day hint
    if(allDayEvents.length===0&&QUIET_INSIGHTS[day]){
      const quiet=document.createElement('div');
      quiet.className='day-event-mini sign';
      quiet.style.opacity='.6';
      quiet.textContent='☽ Daily insight';
      evContainer.appendChild(quiet);
    }
    
    cell.appendChild(evContainer);
    cell.addEventListener('click',()=>openDetail(day));
    row.appendChild(cell);
    
    if((startDay+day)%7===0){
      grid.appendChild(row);
      row=document.createElement('div');
      row.className='week-row';
    }
  }
  
  const remaining=7-((startDay+30)%7);
  if(remaining<7){
    for(let i=0;i<remaining;i++){
      const empty=document.createElement('div');
      empty.className='day-cell empty';row.appendChild(empty);
    }
  }
  grid.appendChild(row);
}

function openDetail(day){
  const dayEvents=EVENTS.filter(e=>e.day===day);
  const moonSign=MOON_SIGNS[day];
  const guide=moonSign?MOON_GUIDE[moonSign]:null;
  const weekdays=['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
  const date=new Date(2026,3,day);
  const weekday=weekdays[date.getDay()];
  
  // Find prev/next days with content
  let prevDay=null,nextDay=null;
  for(let d=day-1;d>=1;d--){if(EVENTS.some(e=>e.day===d)||QUIET_INSIGHTS[d]){prevDay=d;break;}}
  for(let d=day+1;d<=30;d++){if(EVENTS.some(e=>e.day===d)||QUIET_INSIGHTS[d]){nextDay=d;break;}}
  // Actually let's allow nav to any day
  prevDay=day>1?day-1:null;
  nextDay=day<30?day+1:null;
  
  let html=`<div class="detail-nav">
    <button class="nav-btn" ${prevDay?`onclick="openDetail(${prevDay})"`:'disabled'}>&larr; Apr ${prevDay||''}</button>
    <button class="nav-btn" ${nextDay?`onclick="openDetail(${nextDay})"`:'disabled'}>Apr ${nextDay||''} &rarr;</button>
  </div>`;
  
  html+=`<div class="detail-date">${weekday}, April ${day}</div>`;
  if(moonSign)html+=`<div class="detail-moon-sign">☽ Moon in ${moonSign}</div>`;
  
  if(guide){
    html+=`<div class="moon-guide">
      <h5>Moon in ${moonSign} Energy</h5>
      <div class="energy">${guide.energy}</div>
      <div class="do-dont">
        <div class="do-col"><h6>CEO Do's</h6><ul>${guide.dos.map(d=>'<li>'+d+'</li>').join('')}</ul></div>
        <div class="dont-col"><h6>Watch Out</h6><ul>${guide.donts.map(d=>'<li>'+d+'</li>').join('')}</ul></div>
      </div>
    </div>`;
  }
  
  if(dayEvents.length>0){
    html+=`<div class="detail-section"><h4>Transits & Events</h4>`;
    dayEvents.forEach(ev=>{
      html+=`<div class="event-item">
        <span class="event-type ${ev.type}">${ev.type==='phase'?'Lunar Phase':ev.type==='planet'?'Planetary Shift':ev.type==='sign'?'Sign Change':'Aspect'}</span>
        <div class="event-title">${ev.title}</div>
        <div class="event-desc">${ev.desc}</div>
        ${ev.ceo?`<div class="event-ceo"><div class="label">Cosmic CEO Insight</div><p>${ev.ceo}</p></div>`:''}
      </div>`;
    });
    html+='</div>';
  }
  
  if(dayEvents.length===0){
    const quiet=QUIET_INSIGHTS[day];
    html+=`<div class="detail-section"><div class="quiet-day">${quiet||'A quieter cosmic day. Use the lunar energy above to guide your focus. Sometimes the most powerful move is stillness with intention.'}</div></div>`;
  }
  
  detailContent.innerHTML=html;
  overlay.classList.add('open');
  document.body.style.overflow='hidden';
  // Scroll panel to top
  document.getElementById('detailPanel').scrollTop=0;
}

// Make openDetail global for nav buttons
window.openDetail=openDetail;

function closeDetail(){
  overlay.classList.remove('open');
  document.body.style.overflow='';
}

closeBtn.addEventListener('click',closeDetail);
overlay.addEventListener('click',e=>{if(e.target===overlay)closeDetail();});
document.addEventListener('keydown',e=>{if(e.key==='Escape')closeDetail();});

document.querySelectorAll('.filter-btn').forEach(btn=>{
  btn.addEventListener('click',()=>{
    document.querySelectorAll('.filter-btn').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');
    buildCalendar(btn.dataset.filter);
  });
});

buildCalendar('all');
</script>
