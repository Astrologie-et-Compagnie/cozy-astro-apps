<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Cozy Astro - April 2026 Cosmic Calendar</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400;1,500&family=Lora:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#0c0916;
  --surface:#13102a;
  --card:#1a1535;
  --card-hover:#201a42;
  --gold:#c9a84c;
  --gold-dim:#8a7235;
  --gold-glow:rgba(201,168,76,.15);
  --cream:#e8dcc8;
  --cream-dim:rgba(232,220,200,.5);
  --purple:#7b5ea7;
  --purple-dim:#5a4080;
  --rose:#c77d8a;
  --teal:#6aad9e;
  --fire:#d4845a;
  --water:#6a8fc7;
  --earth:#8aad6a;
  --air:#c7b86a;
  --border:rgba(201,168,76,.12);
  --border-active:rgba(201,168,76,.35);
  --radius:8px;
}
html{scroll-behavior:smooth}
body{
  background:var(--bg);
  color:var(--cream);
  font-family:'Lora',serif;
  min-height:100vh;
  line-height:1.6;
}
body::before{
  content:'';position:fixed;inset:0;pointer-events:none;z-index:0;
  background:
    radial-gradient(1px 1px at 8% 15%,rgba(255,255,255,.45) 50%,transparent 100%),
    radial-gradient(1.2px 1.2px at 22% 68%,rgba(201,168,76,.5) 50%,transparent 100%),
    radial-gradient(1px 1px at 45% 12%,rgba(255,255,255,.35) 50%,transparent 100%),
    radial-gradient(1px 1px at 67% 45%,rgba(201,168,76,.35) 50%,transparent 100%),
    radial-gradient(1px 1px at 88% 25%,rgba(255,255,255,.4) 50%,transparent 100%),
    radial-gradient(1.3px 1.3px at 35% 82%,rgba(201,168,76,.4) 50%,transparent 100%),
    radial-gradient(1px 1px at 72% 78%,rgba(255,255,255,.3) 50%,transparent 100%),
    radial-gradient(1px 1px at 55% 55%,rgba(123,94,167,.4) 50%,transparent 100%);
  animation:twinkle 10s ease-in-out infinite alternate;
}
@keyframes twinkle{0%{opacity:.5}50%{opacity:.9}100%{opacity:.6}}

.container{
  position:relative;z-index:1;
  max-width:1060px;margin:0 auto;
  padding:40px 16px 60px;
}

/* HEADER */
header{text-align:center;margin-bottom:44px}
header h1{
  font-family:'Cormorant Garamond',serif;
  font-weight:300;font-size:clamp(2rem,5vw,3.2rem);
  color:var(--gold);letter-spacing:.12em;
  text-transform:uppercase;margin-bottom:6px;
}
header .subtitle{
  font-size:clamp(1rem,2.5vw,1.3rem);
  font-family:'Cormorant Garamond',serif;
  font-weight:500;font-style:italic;
  color:var(--cream-dim);margin-bottom:20px;
}
.ornament{
  width:140px;height:1px;margin:0 auto;
  background:linear-gradient(90deg,transparent,var(--gold),transparent);
  position:relative;
}
.ornament::before{
  content:'✦';position:absolute;left:50%;top:50%;
  transform:translate(-50%,-50%);
  color:var(--gold);font-size:11px;
  background:var(--bg);padding:0 10px;
}

/* MONTH OVERVIEW */
.month-overview{
  display:grid;grid-template-columns:1fr 1fr;gap:16px;
  margin-bottom:36px;
}
.overview-card{
  background:var(--card);border:1px solid var(--border);
  border-radius:var(--radius);padding:20px;
  transition:border-color .3s;
}
.overview-card:hover{border-color:var(--border-active)}
.overview-card h3{
  font-family:'Cormorant Garamond',serif;
  font-size:1.05rem;font-weight:600;
  color:var(--gold);margin-bottom:8px;
  letter-spacing:.04em;text-transform:uppercase;
}
.overview-card p{font-size:.85rem;color:var(--cream-dim);line-height:1.7}

/* LEGEND */
.legend{
  display:flex;flex-wrap:wrap;gap:14px;
  justify-content:center;margin-bottom:24px;
  font-size:.7rem;color:var(--cream-dim);
}
.legend-item{display:flex;align-items:center;gap:5px}
.legend-dot{width:8px;height:8px;border-radius:50%}
.legend-dot.phase{background:var(--gold)}
.legend-dot.planet{background:var(--purple)}
.legend-dot.sign{background:var(--teal)}
.legend-dot.aspect{background:var(--rose)}

/* FILTERS */
.filters{
  display:flex;flex-wrap:wrap;gap:8px;
  margin-bottom:28px;justify-content:center;
}
.filter-btn{
  background:var(--card);border:1px solid var(--border);
  color:var(--cream-dim);font-family:'Lora',serif;
  font-size:.78rem;padding:6px 14px;
  border-radius:20px;cursor:pointer;
  transition:all .25s;
}
.filter-btn:hover,.filter-btn.active{
  border-color:var(--gold);color:var(--gold);
  background:var(--gold-glow);
}

/* CALENDAR GRID */
.week-row{
  display:grid;
  grid-template-columns:repeat(7,1fr);
  gap:3px;margin-bottom:3px;
}
.day-header{
  font-family:'Cormorant Garamond',serif;
  font-size:.78rem;text-transform:uppercase;
  letter-spacing:.1em;color:var(--gold-dim);
  text-align:center;padding:10px 0;
}
.day-cell{
  background:var(--card);
  border:1px solid var(--border);
  border-radius:5px;
  min-height:120px;
  padding:8px 8px 6px;
  cursor:pointer;
  transition:all .25s;
  position:relative;
  display:flex;
  flex-direction:column;
}
.day-cell:hover{border-color:var(--border-active);background:var(--card-hover)}
.day-cell.has-phase{border-color:rgba(201,168,76,.25)}
.day-cell.has-planet{border-color:rgba(123,94,167,.3)}
.day-cell.empty{background:transparent;border-color:transparent;cursor:default;min-height:0}
.day-cell.empty:hover{background:transparent;border-color:transparent}

.day-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:4px}
.day-num{
  font-family:'Cormorant Garamond',serif;
  font-size:1.15rem;font-weight:600;color:var(--cream);
}
.day-moon-badge{
  font-size:.55rem;
  color:var(--purple);
  background:rgba(123,94,167,.12);
  padding:1px 6px;
  border-radius:8px;
  white-space:nowrap;
  letter-spacing:.02em;
}

.day-events{flex:1;display:flex;flex-direction:column;gap:2px;overflow:hidden}
.day-event-mini{
  font-size:.6rem;
  line-height:1.35;
  padding:2px 5px;
  border-radius:3px;
  white-space:nowrap;
  overflow:hidden;
  text-overflow:ellipsis;
  letter-spacing:.01em;
}
.day-event-mini.phase{background:rgba(201,168,76,.12);color:var(--gold)}
.day-event-mini.planet{background:rgba(123,94,167,.15);color:var(--purple)}
.day-event-mini.sign{background:rgba(106,173,158,.12);color:var(--teal)}
.day-event-mini.aspect{background:rgba(199,125,138,.1);color:var(--rose)}
.day-more{
  font-size:.55rem;color:var(--cream-dim);
  text-align:right;margin-top:auto;
  padding-top:2px;font-style:italic;
}

/* Tap hint on mobile */
.tap-hint{
  text-align:center;font-size:.72rem;
  color:var(--cream-dim);opacity:.4;
  margin-bottom:20px;font-style:italic;
}

/* DETAIL PANEL */
.detail-overlay{
  display:none;position:fixed;inset:0;z-index:100;
  background:rgba(10,7,18,.88);
  backdrop-filter:blur(6px);
  overflow-y:auto;
  padding:40px 20px;
}
.detail-overlay.open{display:flex;justify-content:center;align-items:flex-start}
.detail-panel{
  background:var(--surface);
  border:1px solid var(--border-active);
  border-radius:12px;
  max-width:640px;width:100%;
  padding:36px 32px;
  position:relative;
  animation:fadeUp .35s ease;
}
@keyframes fadeUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
.detail-close{
  position:absolute;top:16px;right:20px;
  background:none;border:none;color:var(--cream-dim);
  font-size:1.4rem;cursor:pointer;
  transition:color .2s;
}
.detail-close:hover{color:var(--gold)}

/* Nav arrows */
.detail-nav{display:flex;justify-content:space-between;margin-bottom:16px}
.nav-btn{
  background:none;border:1px solid var(--border);
  color:var(--cream-dim);font-family:'Cormorant Garamond',serif;
  font-size:.8rem;padding:4px 14px;border-radius:16px;
  cursor:pointer;transition:all .2s;
}
.nav-btn:hover{border-color:var(--gold);color:var(--gold)}
.nav-btn:disabled{opacity:.2;cursor:default}
.nav-btn:disabled:hover{border-color:var(--border);color:var(--cream-dim)}

.detail-date{
  font-family:'Cormorant Garamond',serif;
  font-size:1.6rem;font-weight:300;
  color:var(--gold);margin-bottom:4px;
}
.detail-moon-sign{
  font-size:.9rem;color:var(--purple);
  margin-bottom:20px;font-style:italic;
}
.detail-section{margin-bottom:20px}
.detail-section h4{
  font-family:'Cormorant Garamond',serif;
  font-size:1rem;font-weight:600;
  color:var(--gold);margin-bottom:8px;
  letter-spacing:.04em;text-transform:uppercase;
}
.event-item{
  background:var(--card);
  border:1px solid var(--border);
  border-radius:6px;
  padding:14px 16px;
  margin-bottom:8px;
  transition:border-color .2s;
}
.event-item:hover{border-color:var(--border-active)}
.event-title{
  font-family:'Cormorant Garamond',serif;
  font-size:.95rem;font-weight:600;
  color:var(--cream);margin-bottom:4px;
}
.event-type{
  display:inline-block;
  font-size:.65rem;text-transform:uppercase;
  letter-spacing:.08em;padding:2px 8px;
  border-radius:10px;margin-bottom:6px;
}
.event-type.phase{background:rgba(201,168,76,.15);color:var(--gold)}
.event-type.planet{background:rgba(123,94,167,.2);color:var(--purple)}
.event-type.sign{background:rgba(106,173,158,.15);color:var(--teal)}
.event-type.aspect{background:rgba(199,125,138,.15);color:var(--rose)}
.event-desc{font-size:.82rem;color:var(--cream-dim);line-height:1.7}
.event-ceo{
  margin-top:10px;padding:10px 14px;
  background:rgba(201,168,76,.06);
  border-left:2px solid var(--gold-dim);
  border-radius:0 6px 6px 0;
}
.event-ceo .label{
  font-family:'Cormorant Garamond',serif;
  font-size:.72rem;font-weight:600;
  color:var(--gold);text-transform:uppercase;
  letter-spacing:.08em;margin-bottom:4px;
}
.event-ceo p{font-size:.8rem;color:var(--cream);line-height:1.65}

/* MOON GUIDE */
.moon-guide{
  margin-top:14px;
  padding:14px 16px;
  background:var(--card);
  border:1px solid var(--border);
  border-radius:6px;
}
.moon-guide h5{
  font-family:'Cormorant Garamond',serif;
  font-size:.88rem;font-weight:600;
  color:var(--purple);margin-bottom:6px;
}
.moon-guide .energy{font-size:.8rem;color:var(--cream-dim);line-height:1.65;margin-bottom:8px}
.do-dont{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.do-col h6,.dont-col h6{
  font-size:.7rem;text-transform:uppercase;
  letter-spacing:.08em;margin-bottom:6px;
}
.do-col h6{color:var(--teal)}
.dont-col h6{color:var(--rose)}
.do-col li,.dont-col li{
  font-size:.75rem;color:var(--cream-dim);
  margin-bottom:4px;list-style:none;padding-left:14px;
  position:relative;line-height:1.5;
}
.do-col li::before{content:'✦';position:absolute;left:0;color:var(--teal);font-size:.55rem;top:2px}
.dont-col li::before{content:'✦';position:absolute;left:0;color:var(--rose);font-size:.55rem;top:2px}

/* QUIET DAY */
.quiet-day{
  font-size:.82rem;color:var(--cream-dim);
  font-style:italic;line-height:1.65;
  padding:8px 0;
}

/* FOOTER */
footer{
  text-align:center;padding:40px 20px 20px;
  font-size:.72rem;color:var(--cream-dim);
  opacity:.4;letter-spacing:.04em;
}

/* RESPONSIVE */
@media(max-width:800px){
  .month-overview{grid-template-columns:1fr}
  .day-cell{min-height:90px;padding:6px 5px 4px}
  .day-num{font-size:1rem}
  .day-event-mini{font-size:.55rem;padding:1px 4px}
  .detail-panel{padding:24px 18px}
  .do-dont{grid-template-columns:1fr}
}
@media(max-width:520px){
  .day-header{font-size:.6rem;letter-spacing:.05em}
  .day-cell{min-height:72px;padding:4px 3px 3px}
  .day-num{font-size:.88rem}
  .day-moon-badge{font-size:.48rem;padding:1px 4px}
  .day-event-mini{font-size:.5rem}
  .day-more{font-size:.48rem}
  .week-row{gap:2px;margin-bottom:2px}
}
</style>
</head>
